# Ignore Python bytecode files
*.pyc
*.pyo
*.pyd
__pycache__/

# Ignore virtual environment directories
venv/
env/
.env
.venv/
.vscode/

# Ignore Model and result directories 
models/phobert_finetuned_model/
models/phobert_tokenizer/
models/phobert
result/

# ignore raw data files
data/**/*.csv
data/**/*.json
data/**/*.parquet

# BUT keep DVC metadata
!data/**/*.dvc
mlruns/


# Terraform
terraform.tfvars
iac/terraform/*.tfstate
iac/terraform/*.tfstate.backup
iac/terraform/gke/*.tfstate
iac/terraform/gke/*.tfstate.backup
iac/terraform/gke/.terraform/
iac/terraform/gke/.terraform.lock.hcl
